# LUMA RH — Variáveis de ambiente para migração
# Copie este arquivo para .env e preencha os valores

# Supabase
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_KEY=SEU_SERVICE_ROLE_KEY   # Project Settings → API → service_role (NUNCA expor no frontend)

# Microsoft Graph — token obtido na sessão autenticada do editor
# Abrir o editor, F12 → Console → copiar: window.tok
MS_GRAPH_TOKEN=SEU_TOKEN_BEARER

# IDs do arquivo Excel no OneDrive (copiar do editor: CFG.driveId e CFG.itemId)
